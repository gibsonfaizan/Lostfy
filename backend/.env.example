# LostFy Backend Environment Configuration
# Copy this file to .env and fill in real values

PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=lostfy

# JWT Secret Keys
JWT_SECRET=lostfy_jwt_secret_change_in_production_2026
JWT_REFRESH_SECRET=lostfy_refresh_secret_change_in_production_2026
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# AI Service URL
AI_SERVICE_URL=http://localhost:8000

# File Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_MAX_FILES=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
